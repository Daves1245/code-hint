{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "composite": true,
    "rootDir": "./src",
    "outDir": "../dist/api",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    // workspace packages (store, include) point "main" at raw .ts source with
    // no "exports" map, which nodenext's stricter deep-import resolution can't
    // follow. bundler resolution plus the project references below (which
    // resolve store/include through their own composite build) is what
    // actually makes these deep imports work.
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"],
  "references": [{ "path": "../store" }, { "path": "../include" }]
}
