{
  "name": "code-hint",
  "version": "1.0.0",
  "description": "A badly written code assistant",
  "type": "module",
  "main": "dist/api/index.js",
  "workspaces": [
    "agents",
    "api",
    "cli",
    "evals",
    "include",
    "scripts",
    "store"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "tsx watch api/src/index.ts",
    "dev:cli": "tsx cli/src/index.tsx",
    "run:script": "tsx scripts/src/run.ts",
    "start:api": "node dist/api/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.20.0",
    "@types/typescript": "^0.4.29",
    "eslint": "^10.6.0",
    "prettier": "3.9.4",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
